<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Glow effect (subtle outer stroke) -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="16dp" />
            <stroke android:width="2dp" android:color="@color/neon_green_glow" />
        </shape>
    </item>
    <!-- Main Background -->
    <item android:left="1dp" android:right="1dp" android:top="1dp" android:bottom="1dp">
        <shape android:shape="rectangle">
            <corners android:radius="16dp" />
            <solid android:color="@color/card_cyber" />
            <stroke android:width="1dp" android:color="@color/neon_green" />
        </shape>
    </item>
</layer-list>
