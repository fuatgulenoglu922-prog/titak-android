<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Minimalist Animation (Subtle) -->
    <style name="Theme.Titak.Animation">
        <item name="android:activityOpenEnterAnimation">@anim/theme_enter</item>
        <item name="android:activityOpenExitAnimation">@anim/theme_exit</item>
        <item name="android:activityCloseEnterAnimation">@anim/theme_enter_reverse</item>
        <item name="android:activityCloseExitAnimation">@anim/theme_exit_reverse</item>
    </style>

    <style name="Theme.Titak" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/brand_blurple</item>
        <item name="colorPrimaryVariant">@color/brand_blurple</item>
        <item name="colorOnPrimary">@color/text_bright</item>
        
        <item name="colorSecondary">@color/bg_dark_secondary</item>
        <item name="colorSecondaryVariant">@color/bg_dark_secondary</item>
        <item name="colorOnSecondary">@color/text_normal</item>
        
        <item name="android:colorBackground">@color/bg_dark_primary</item>
        <item name="colorSurface">@color/bg_dark_secondary</item>
        <item name="colorOnSurface">@color/text_normal</item>
        
        <item name="android:statusBarColor">@color/bg_dark_tertiary</item>
        <item name="android:navigationBarColor">@color/bg_dark_tertiary</item>
        <item name="android:windowAnimationStyle">@style/Theme.Titak.Animation</item>
    </style>

</resources>
