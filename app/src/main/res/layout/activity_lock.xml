<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="28dp"
    android:background="@color/bg_cyber">

    <ImageView
        android:id="@+id/iv_lock_icon"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:src="@drawable/ic_coin"
        android:background="@drawable/bg_neon_card"
        android:padding="16dp"
        app:tint="@color/neon_green"
        android:layout_marginBottom="20dp" />

    <TextView
        android:id="@+id/tv_lock_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="TiTak"
        android:textColor="@color/neon_green"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="4dp" />

    <TextView
        android:id="@+id/tv_lock_sub"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Şifre girin"
        android:textColor="@color/text_mid"
        android:textSize="11sp"
        android:layout_marginBottom="24dp" />

    <EditText
        android:id="@+id/et_lock_password"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:hint="Şifre"
        android:textColor="@color/white"
        android:textColorHint="@color/text_low"
        android:gravity="center"
        android:inputType="textPassword"
        android:background="@drawable/bg_neon_card"
        android:paddingHorizontal="16dp" />

    <Button
        android:id="@+id/btn_unlock"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginTop="20dp"
        android:text="Giriş"
        android:textStyle="bold"
        android:backgroundTint="@color/neon_green"
        android:textColor="@color/black"
        style="@style/Widget.MaterialComponents.Button" />

</LinearLayout>
