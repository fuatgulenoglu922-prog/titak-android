<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_cyber"
    android:gravity="center"
    android:padding="32dp">

    <ImageView
        android:id="@+id/iv_lock_icon"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:src="@drawable/ic_coin"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="32dp"
        app:tint="@color/neon_green"
        android:background="@drawable/bg_neon_card"
        android:padding="20dp" />

    <TextView
        android:id="@+id/tv_lock_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/iv_lock_icon"
        android:layout_centerHorizontal="true"
        android:text="SECURE ACCESS"
        android:textColor="@color/neon_green"
        android:textSize="22sp"
        android:textStyle="bold"
        android:letterSpacing="0.2"/>

    <TextView
        android:id="@+id/tv_lock_sub"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/tv_lock_title"
        android:layout_centerHorizontal="true"
        android:text="AUTHORIZATION REQUIRED"
        android:textColor="@color/neon_green_dim"
        android:textSize="10sp"
        android:letterSpacing="0.1"
        android:layout_marginTop="8dp"/>

    <EditText
        android:id="@+id/et_lock_password"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_below="@id/tv_lock_sub"
        android:layout_marginTop="48dp"
        android:hint="[ KEYCODE ]"
        android:textColor="@color/white"
        android:textColorHint="@color/text_low"
        android:gravity="center"
        android:inputType="textPassword"
        android:background="@drawable/bg_neon_card"
        android:fontFamily="monospace"
        android:letterSpacing="0.5" />

    <Button
        android:id="@+id/btn_unlock"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_below="@id/et_lock_password"
        android:layout_marginTop="32dp"
        android:text="VALIDATE"
        android:textStyle="bold"
        android:backgroundTint="@color/neon_green"
        android:textColor="@color/black"
        style="@style/Widget.MaterialComponents.Button" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/btn_unlock"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="24dp"
        android:text="TITAK SECURITY INTERFACE"
        android:textColor="@color/text_low"
        android:textSize="8sp"
        android:letterSpacing="0.2" />

</RelativeLayout>
