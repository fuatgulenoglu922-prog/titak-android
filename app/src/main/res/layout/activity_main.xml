<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_cyber"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Başlık — sade -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="TiTak"
                android:textSize="22sp"
                android:textColor="@color/text_high"
                android:textStyle="bold"
                android:letterSpacing="0.05" />

            <TextView
                android:id="@+id/tv_version"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="@color/status_info"
                android:background="@drawable/bg_neon_card"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- İzin kartları — kompakt -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="24dp">

            <androidx.cardview.widget.CardView
                android:id="@+id/card_overlay"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/transparent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_neon_card"
                    android:gravity="center_vertical"
                    android:padding="14dp">

                    <ImageView
                        android:id="@+id/icon_overlay"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_warning"
                        android:tint="@color/neon_green"
                        android:layout_marginEnd="12dp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Ekran üstü izni"
                            android:textColor="@color/text_high"
                            android:textStyle="bold"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/tv_overlay_status"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="❌ İzin gerekli"
                            android:textColor="@color/accent_red"
                            android:textSize="10sp"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/card_accessibility"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/transparent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_neon_card"
                    android:gravity="center_vertical"
                    android:padding="14dp">

                    <ImageView
                        android:id="@+id/icon_accessibility"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_warning"
                        android:tint="@color/neon_green"
                        android:layout_marginEnd="12dp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Erişilebilirlik servisi"
                            android:textColor="@color/text_high"
                            android:textStyle="bold"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/tv_accessibility_status"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="❌ Kapalı"
                            android:textColor="@color/accent_red"
                            android:textSize="10sp"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <!-- Şablonlar — sade başlık -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Şablon fotoğrafları"
            android:textColor="@color/text_mid"
            android:textSize="11sp"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="3"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="6dp">

                <ImageView
                    android:id="@+id/img_tpl_chest"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:background="@drawable/bg_neon_card"
                    android:padding="4dp"
                    android:scaleType="centerCrop"
                    android:src="@android:drawable/ic_menu_camera" />
                 <TextView
                     android:layout_width="wrap_content"
                     android:layout_height="wrap_content"
                     android:text="Sandık"
                     android:gravity="center"
                     android:textSize="10sp"
                     android:textColor="@color/accent_green"
                     android:layout_marginTop="6dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="6dp">

                <ImageView
                    android:id="@+id/img_tpl_open"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:background="@drawable/bg_neon_card"
                    android:padding="4dp"
                    android:scaleType="centerCrop"
                    android:src="@android:drawable/ic_menu_camera" />
                 <TextView
                     android:layout_width="wrap_content"
                     android:layout_height="wrap_content"
                     android:text="Aç butonu"
                     android:gravity="center"
                     android:textSize="10sp"
                     android:textColor="@color/accent_green"
                     android:layout_marginTop="6dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="6dp">

                <ImageView
                    android:id="@+id/img_tpl_empty"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:background="@drawable/bg_neon_card"
                    android:padding="4dp"
                    android:scaleType="centerCrop"
                    android:src="@android:drawable/ic_menu_camera" />
                 <TextView
                     android:layout_width="wrap_content"
                     android:layout_height="wrap_content"
                     android:text="Boş çıktı"
                     android:gravity="center"
                     android:textSize="10sp"
                     android:textColor="@color/accent_green"
                     android:layout_marginTop="6dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Ana butonlar -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/transparent"
            android:layout_marginBottom="12dp">

            <Button
                android:id="@+id/btn_start_overlay"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Botu başlat"
                android:textSize="15sp"
                android:textStyle="bold"
                android:background="@drawable/btn_neon_main"
                android:textColor="@color/black"
                android:stateListAnimator="@null"
                style="@style/Widget.MaterialComponents.Button" />
        </androidx.cardview.widget.CardView>

            <Button
                android:id="@+id/btn_stop_bot"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Durdur"
                android:textSize="13sp"
                android:textStyle="bold"
                android:backgroundTint="@color/transparent"
                android:textColor="@color/accent_red"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_marginBottom="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="4"
            android:layout_marginBottom="8dp">

            <Button
                android:id="@+id/btn_update_app"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:text="Güncelle"
                android:textSize="11sp"
                android:backgroundTint="@color/panel_cyber"
                android:textColor="@color/status_info"
                style="@style/Widget.MaterialComponents.Button" />

            <Button
                android:id="@+id/btn_api"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:text="Yapay Zeka API"
                android:textSize="11sp"
                android:backgroundTint="@color/panel_cyber"
                android:textColor="@color/neon_cyan"
                style="@style/Widget.MaterialComponents.Button" />

            <Button
                android:id="@+id/btn_settings"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:text="Ayarlar"
                android:textSize="11sp"
                android:backgroundTint="@color/panel_cyber"
                android:textColor="@color/text_high"
                style="@style/Widget.MaterialComponents.Button" />

            <Button
                android:id="@+id/btn_feedback"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:text="Geri Bildirim"
                android:textSize="11sp"
                android:backgroundTint="@color/panel_cyber"
                android:textColor="@color/accent_green"
                style="@style/Widget.MaterialComponents.Button" />
        </LinearLayout>

        <!-- Bilgi — kısa -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="14dp"
            android:background="@drawable/bg_neon_card"
            android:text="Botu başlattıktan sonra TikTok'u açın. Sandık görününce otomatik tıklar."
            android:textColor="@color/text_mid"
            android:textSize="11sp"
            android:lineSpacingExtra="2dp" />
    </LinearLayout>
</ScrollView>
