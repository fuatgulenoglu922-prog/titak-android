<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D0F12">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#1A1C21"
        android:paddingHorizontal="20dp"
        android:elevation="8dp"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="TiTak 5.2"
            android:textSize="24sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_version"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="#888888"
            android:layout_marginEnd="10dp"
            android:text="v5.2" />

        <ImageView
            android:id="@+id/btn_invite_friend"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_share"
            android:padding="8dp"
            app:tint="#4CAF50" />

        <!-- Hidden button to keep IDs compatible -->
        <View android:id="@+id/btn_google_login" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:gravity="center_horizontal">

            <!-- Real Radio Visual Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="320dp"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="30dp"
                app:cardBackgroundColor="#22252A"
                app:cardElevation="15dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="20dp">

                    <View
                        android:id="@+id/antenna"
                        android:layout_width="12dp"
                        android:layout_height="40dp"
                        android:layout_alignParentTop="true"
                        android:layout_marginStart="40dp"
                        android:background="#111111" />

                    <TextView
                        android:id="@+id/tv_user_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerHorizontal="true"
                        android:layout_marginTop="30dp"
                        android:text="TELSİZ SİSTEMİ ÇEVRİMİÇİ"
                        android:textColor="#4CAF50"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <ImageView
                        android:layout_width="140dp"
                        android:layout_height="140dp"
                        android:layout_centerInParent="true"
                        android:src="@android:drawable/ic_btn_speak_now"
                        android:alpha="0.4"
                        app:tint="#FFFFFF" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentBottom="true"
                        android:layout_centerHorizontal="true"
                        android:layout_marginBottom="10dp"
                        android:text="POLICE RADIO EDITION"
                        android:textColor="#555555"
                        android:textSize="10sp"
                        android:textStyle="bold" />
                </RelativeLayout>
            </androidx.cardview.widget.CardView>

            <!-- Menu Grid -->
            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:rowCount="2"
                android:layout_marginBottom="20dp">

                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    app:cardCornerRadius="15dp"
                    app:cardBackgroundColor="#5865F2">
                    <LinearLayout
                        android:id="@+id/btn_social_hub"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:clickable="true"
                        android:focusable="true">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="💬" android:textSize="24sp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="ARKADAŞLAR" android:textColor="#FFFFFF" android:textStyle="bold" android:textSize="12sp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    app:cardCornerRadius="15dp"
                    app:cardBackgroundColor="#FEE75C">
                    <LinearLayout
                        android:id="@+id/btn_pro_features"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:clickable="true"
                        android:focusable="true">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="💎" android:textSize="24sp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="PRO PANEL" android:textColor="#23272A" android:textStyle="bold" android:textSize="12sp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    app:cardCornerRadius="15dp"
                    app:cardBackgroundColor="#2D2D2D">
                    <LinearLayout
                        android:id="@+id/btn_settings"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:clickable="true"
                        android:focusable="true">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="⚙️" android:textSize="24sp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="AYARLAR" android:textColor="#FFFFFF" android:textStyle="bold" android:textSize="12sp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    app:cardCornerRadius="15dp"
                    app:cardBackgroundColor="#2D2D2D">
                    <LinearLayout
                        android:id="@+id/btn_profile"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:clickable="true"
                        android:focusable="true">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="👤" android:textSize="24sp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="PROFİL" android:textColor="#FFFFFF" android:textStyle="bold" android:textSize="12sp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </GridLayout>

            <Button
                android:id="@+id/btn_update_app"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="GÜNCELLEMEYİ KONTROL ET"
                android:backgroundTint="#EB459E"
                android:textColor="#FFFFFF"
                android:layout_marginTop="10dp"
                app:cornerRadius="12dp"/>

            <Button
                android:id="@+id/btn_feedback"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="🛡️ DESTEK VE YARDIM"
                android:backgroundTint="#2D2D2D"
                android:textColor="#AAAAAA"
                android:layout_marginTop="12dp"
                app:cornerRadius="12dp"/>

            <Button
                android:id="@+id/btn_music_toggle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="🎵 Müziği Aç/Kapat"
                android:backgroundTint="#1A1C21"
                android:textColor="#888888"
                android:textSize="10sp" />

        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
