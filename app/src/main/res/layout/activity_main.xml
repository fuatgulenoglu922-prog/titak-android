<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_dark_primary">

    <!-- Header / Custom App Bar (Like Discord Top Bar) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/bg_dark_tertiary"
        android:paddingHorizontal="16dp"
        android:elevation="4dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="TiTak"
            android:textSize="20sp"
            android:textColor="@color/text_bright"
            android:textStyle="bold"
            android:fontFamily="sans-serif-black" />

        <TextView
            android:id="@+id/tv_version"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="@color/text_muted"
            android:background="@drawable/bg_neon_card"
            android:backgroundTint="@color/bg_dark_floating"
            android:paddingHorizontal="8dp"
            android:paddingVertical="4dp"
            android:textStyle="bold"
            android:layout_marginEnd="16dp" />

        <ImageView
            android:id="@+id/btn_google_login"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_coin"
            android:background="@drawable/bg_neon_card"
            android:padding="8dp"
            app:tint="@color/text_normal" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- User Status Card (Discord Profile Banner Style) -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/bg_dark_secondary">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp"
                    android:gravity="center">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        
                        <View
                            android:layout_width="12dp"
                            android:layout_height="12dp"
                            android:background="@drawable/bg_neon_card"
                            android:backgroundTint="@color/status_online"
                            android:layout_marginEnd="8dp"/>

                        <TextView
                            android:id="@+id/tv_user_status"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Çevrimiçi"
                            android:textColor="@color/text_bright"
                            android:textSize="18sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="İletişime Hazır"
                        android:textColor="@color/text_muted"
                        android:textSize="14sp"
                        android:layout_marginTop="4dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Server Actions / Features -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ÖNE ÇIKANLAR"
                android:textColor="@color/text_dark"
                android:fontFamily="sans-serif-medium"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"
                android:layout_marginStart="4dp"/>

            <Button
                android:id="@+id/btn_pro_features"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="💎 PRO ÖZELLİKLER (SES DEĞİŞTİRİCİ)"
                android:textSize="14sp"
                android:textStyle="bold"
                android:background="@drawable/btn_neon_main"
                android:textColor="@color/text_bright"
                android:layout_marginBottom="16dp"
                android:elevation="2dp"
                android:stateListAnimator="@null"
                style="@style/Widget.MaterialComponents.Button" />
                
            <Button
                android:id="@+id/btn_music_toggle"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="🔊 Arka Plan Müziği: Açık"
                android:textSize="14sp"
                android:textStyle="bold"
                android:backgroundTint="@color/bg_dark_secondary"
                android:textColor="@color/text_normal"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_marginBottom="24dp" />

            <!-- Social / Navigation -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AĞ &amp; SOSYAL"
                android:textColor="@color/text_dark"
                android:fontFamily="sans-serif-medium"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"
                android:layout_marginStart="4dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2"
                android:layout_marginBottom="24dp">

                <Button
                    android:id="@+id/btn_profile"
                    android:layout_width="0dp"
                    android:layout_height="64dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:text="👤 PROFİLİM"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:backgroundTint="@color/bg_dark_secondary"
                    android:textColor="@color/text_bright"
                    style="@style/Widget.MaterialComponents.Button" />

                <Button
                    android:id="@+id/btn_social_hub"
                    android:layout_width="0dp"
                    android:layout_height="64dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:text="💬 ARKADAŞLAR"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:backgroundTint="@color/brand_green"
                    android:textColor="@color/bg_dark_tertiary"
                    style="@style/Widget.MaterialComponents.Button" />
            </LinearLayout>

            <!-- Settings / Utilities Grid -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ARAÇLAR"
                android:textColor="@color/text_dark"
                android:fontFamily="sans-serif-medium"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"
                android:layout_marginStart="4dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="4"
                android:layout_marginBottom="24dp">

                <Button
                    android:id="@+id/btn_update_app"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:text="Güncelle"
                    android:textSize="10sp"
                    android:backgroundTint="@color/bg_dark_secondary"
                    android:textColor="@color/brand_blurple"
                    style="@style/Widget.MaterialComponents.Button" />
                    
                <Button
                    android:id="@+id/btn_api"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:text="API"
                    android:textSize="10sp"
                    android:backgroundTint="@color/bg_dark_secondary"
                    android:textColor="@color/text_muted"
                    style="@style/Widget.MaterialComponents.Button" />

                <Button
                    android:id="@+id/btn_settings"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:text="Ayarlar"
                    android:textSize="10sp"
                    android:backgroundTint="@color/bg_dark_secondary"
                    android:textColor="@color/text_muted"
                    style="@style/Widget.MaterialComponents.Button" />

                <Button
                    android:id="@+id/btn_feedback"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:text="Destek"
                    android:textSize="10sp"
                    android:backgroundTint="@color/bg_dark_secondary"
                    android:textColor="@color/brand_yellow"
                    style="@style/Widget.MaterialComponents.Button" />
            </LinearLayout>
            
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/bg_dark_tertiary"
                android:layout_marginBottom="16dp"/>

            <!-- Info text -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="TiTak v3.3 Güvenli Bağlantı"
                android:textColor="@color/text_dark"
                android:textSize="11sp"
                android:gravity="center"
                android:layout_marginBottom="20dp" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>
