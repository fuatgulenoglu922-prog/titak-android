<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_cyber"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Başlık — sade -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="TiTak"
                android:textSize="22sp"
                android:textColor="@color/text_high"
                android:textStyle="bold"
                android:letterSpacing="0.05" />

            <TextView
                android:id="@+id/tv_version"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="@color/status_info"
                android:background="@drawable/bg_neon_card"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- İletişim Durumu -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/transparent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_neon_card"
                android:orientation="vertical"
                android:padding="20dp"
                android:gravity="center">

                <TextView
                    android:id="@+id/tv_user_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Çevrimiçi"
                    android:textColor="@color/accent_green"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="İletişime Hazır"
                    android:textColor="@color/text_mid"
                    android:textSize="12sp"
                    android:layout_marginTop="4dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Hızlı İşlemler -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hızlı İşlemler"
            android:textColor="@color/text_mid"
            android:textSize="11sp"
            android:layout_marginBottom="12dp" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/transparent"
            android:layout_marginBottom="12dp">

            <Button
                android:id="@+id/btn_pro_features"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="PRO ÖZELLİKLER (SES DEĞİŞTİRİCİ)"
                android:textSize="14sp"
                android:textStyle="bold"
                android:background="@drawable/btn_neon_main"
                android:textColor="@color/black"
                android:stateListAnimator="@null"
                style="@style/Widget.MaterialComponents.Button" />
        </androidx.cardview.widget.CardView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="4"
            android:layout_marginBottom="8dp">

            <Button
                android:id="@+id/btn_update_app"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:text="Güncelle"
                android:textSize="11sp"
                android:backgroundTint="@color/panel_cyber"
                android:textColor="@color/status_info"
                style="@style/Widget.MaterialComponents.Button" />

            <Button
                android:id="@+id/btn_api"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:text="Yapay Zeka API"
                android:textSize="11sp"
                android:backgroundTint="@color/panel_cyber"
                android:textColor="@color/neon_cyan"
                style="@style/Widget.MaterialComponents.Button" />

            <Button
                android:id="@+id/btn_settings"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:text="Ayarlar"
                android:textSize="11sp"
                android:backgroundTint="@color/panel_cyber"
                android:textColor="@color/text_high"
                style="@style/Widget.MaterialComponents.Button" />

            <Button
                android:id="@+id/btn_feedback"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:text="Geri Bildirim"
                android:textSize="11sp"
                android:backgroundTint="@color/panel_cyber"
                android:textColor="@color/accent_green"
                style="@style/Widget.MaterialComponents.Button" />
        </LinearLayout>

        <!-- Müzik Kontrol Butonu -->
        <Button
            android:id="@+id/btn_music_toggle"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text=" Muzik: Acik"
            android:textSize="13sp"
            android:textStyle="bold"
            android:backgroundTint="@color/panel_cyber"
            android:textColor="@color/neon_green"
            style="@style/Widget.MaterialComponents.Button"
            android:layout_marginBottom="12dp" />

        <!-- SOSYAL KONTROLLER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2"
            android:layout_marginBottom="12dp">

            <Button
                android:id="@+id/btn_profile"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:text="Profilim"
                android:textSize="14sp"
                android:textStyle="bold"
                android:backgroundTint="#3D5AFE"
                android:textColor="@color/white"
                style="@style/Widget.MaterialComponents.Button" />

            <Button
                android:id="@+id/btn_social_hub"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:text="Sosyal"
                android:textSize="14sp"
                android:textStyle="bold"
                android:backgroundTint="#00E676"
                android:textColor="@color/black"
                style="@style/Widget.MaterialComponents.Button" />
        </LinearLayout>

        <!-- Bilgi — kısa -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="14dp"
            android:background="@drawable/bg_neon_card"
            android:text="Titak v3.2 ile artık tamamen bir iletişim aracıdır. Diğer kullanıcılarla ID üzerinden iletişime geçebilirsiniz."
            android:textColor="@color/text_mid"
            android:textSize="11sp"
            android:lineSpacingExtra="2dp" />
    </LinearLayout>
</ScrollView>
