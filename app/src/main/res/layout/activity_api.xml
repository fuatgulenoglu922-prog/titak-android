<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@color/bg_cyber">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="API Bağlantıcı"
        android:textColor="@color/neon_green"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_neon_card"
        android:orientation="vertical"
        android:padding="16dp"
        android:layout_marginBottom="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Yeni API Ekle"
            android:textColor="@color/neon_cyan"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <EditText
            android:id="@+id/et_api_name"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:hint="API İsmi (OpenAI, Claude vb.)"
            android:textColor="@color/white"
            android:textColorHint="@color/text_low"
            android:backgroundTint="@color/neon_green"
            android:textSize="13sp"
            android:paddingHorizontal="10dp" />

        <EditText
            android:id="@+id/et_api_key"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:hint="API Anahtarı"
            android:textColor="@color/white"
            android:textColorHint="@color/text_low"
            android:inputType="textPassword"
            android:backgroundTint="@color/neon_green"
            android:textSize="13sp"
            android:paddingHorizontal="10dp"
            android:layout_marginTop="8dp" />

        <EditText
            android:id="@+id/et_api_base_url"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:hint="Base URL (opsiyonel)"
            android:textColor="@color/white"
            android:textColorHint="@color/text_low"
            android:backgroundTint="@color/neon_green"
            android:textSize="13sp"
            android:paddingHorizontal="10dp"
            android:layout_marginTop="8dp" />

        <EditText
            android:id="@+id/et_api_model"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:hint="Model (gpt-3.5-turbo vb.)"
            android:textColor="@color/white"
            android:textColorHint="@color/text_low"
            android:backgroundTint="@color/neon_green"
            android:textSize="13sp"
            android:paddingHorizontal="10dp"
            android:layout_marginTop="8dp" />

        <Button
            android:id="@+id/btn_add_api"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:text="Ekle"
            android:backgroundTint="@color/neon_green"
            android:textColor="@color/black"
            android:textStyle="bold"
            android:layout_marginTop="12dp" />

        <Button
            android:id="@+id/btn_clear"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:text="Temizle"
            android:backgroundTint="@color/transparent"
            android:textColor="@color/neon_rose"
            android:textStyle="bold"
            android:layout_marginTop="6dp" />
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Kayıtlı API'ler"
        android:textColor="@color/neon_cyan"
        android:textSize="12sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <ListView
        android:id="@+id/lv_api_keys"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="@color/neon_green"
        android:dividerHeight="1dp" />

</LinearLayout>
