<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@color/bg_cyber">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="CORE CONFIG"
        android:textColor="@color/neon_green"
        android:textSize="24sp"
        android:textStyle="bold"
        android:letterSpacing="0.1"
        android:layout_marginBottom="32dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_neon_card"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PROTECTION PROTOCOL"
            android:textColor="@color/neon_cyan"
            android:textSize="12sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:layout_marginBottom="24dp"/>

        <EditText
            android:id="@+id/et_new_password"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:hint="ENTER NEW KEYCODE"
            android:textColor="@color/white"
            android:textColorHint="@color/text_low"
            android:inputType="textPassword"
            android:backgroundTint="@color/neon_green"
            android:fontFamily="monospace"
            android:textSize="14sp"
            android:paddingHorizontal="12dp"/>

        <Button
            android:id="@+id/btn_save_password"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="ENCRYPT &amp; SAVE"
            android:backgroundTint="@color/neon_green"
            android:textColor="@color/black"
            android:textStyle="bold"
            android:layout_marginTop="24dp"
            style="@style/Widget.MaterialComponents.Button" />

        <Button
            android:id="@+id/btn_disable_password"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="RESCIND PROTECTION"
            android:backgroundTint="@color/transparent"
            android:textColor="@color/neon_rose"
            android:textStyle="bold"
            android:layout_marginTop="8dp"
            style="@style/Widget.MaterialComponents.Button.TextButton" />
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Cyber-encryption active. Protocols will be enforced on next system initialization."
        android:textColor="@color/text_mid"
        android:textSize="10sp"
        android:layout_marginTop="16dp"
        android:gravity="center"
        android:fontFamily="monospace" />

</LinearLayout>
