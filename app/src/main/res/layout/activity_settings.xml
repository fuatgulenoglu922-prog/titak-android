<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#121212">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Uygulama Ayarları"
        android:textColor="#FFFFFF"
        android:textSize="28sp"
        android:textStyle="bold"
        android:layout_marginBottom="32dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1E1E1E"
        android:orientation="vertical"
        android:padding="16dp"
        android:elevation="4dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔒 Güvenlik (Şifre)"
            android:textColor="#FFCC00"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp"/>

        <EditText
            android:id="@+id/et_new_password"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Yeni Şifre Girin"
            android:textColor="#FFFFFF"
            android:textColorHint="#888888"
            android:inputType="textPassword"
            android:backgroundTint="#FFCC00"/>

        <Button
            android:id="@+id/btn_save_password"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Şifreyi Kaydet"
            android:backgroundTint="#FFCC00"
            android:textColor="#000000"
            android:layout_marginTop="16dp"/>

        <Button
            android:id="@+id/btn_disable_password"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Şifreyi Kaldır"
            android:backgroundTint="#444444"
            android:textColor="#FFFFFF"
            android:layout_marginTop="8dp"/>
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Şifre aktifse uygulama her açıldığında sorulacaktır."
        android:textColor="#AAAAAA"
        android:textSize="12sp"
        android:layout_marginTop="8dp"
        android:gravity="center"/>

</LinearLayout>
