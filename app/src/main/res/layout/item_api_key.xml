<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="@drawable/bg_neon_card"
    android:layout_marginBottom="8dp">

    <TextView
        android:id="@+id/tv_api_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="API İsmi"
        android:textColor="@color/neon_green"
        android:textSize="14sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tv_api_base_url"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Base URL"
        android:textColor="@color/text_mid"
        android:textSize="11sp"
        android:layout_marginTop="4dp" />

    <TextView
        android:id="@+id/tv_api_model"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Model"
        android:textColor="@color/text_low"
        android:textSize="10sp"
        android:layout_marginTop="2dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="10dp">

        <Button
            android:id="@+id/btn_set_active"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:text="Aktif Et"
            android:backgroundTint="@color/neon_cyan"
            android:textColor="@color/black"
            android:textSize="11sp"
            android:textStyle="bold"
            android:layout_marginEnd="6dp" />

        <Button
            android:id="@+id/btn_delete"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:text="Sil"
            android:backgroundTint="@color/neon_rose"
            android:textColor="@color/white"
            android:textSize="11sp"
            android:textStyle="bold" />
    </LinearLayout>

</LinearLayout>
